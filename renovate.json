{
  "extends": ["@whtsky"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^LIBARCHIVE_VERSION$"],
      "matchStrings": ["(?<currentValue>v[\\d\\.]+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "libarchive/libarchive"
    }
  ],
  "packageRules": [
    {
      "matchDepNames": ["libarchive/libarchive"],
      "postUpgradeTasks": {
        "commands": ["echo 0 > VERSION"],
        "fileFilters": ["VERSION"],
        "executionMode": "update"
      }
    }
  ]
}
